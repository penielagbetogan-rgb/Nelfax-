# Configuration Environnement Production NELFAX AI
PORT=3000
NODE_ENV=production

# Clé API Google Gemini (IA générative / Assistants)
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# Configuration RunPod Serverless GPU MLOps (Restauration photo 4K/8K)
RUNPOD_URL=https://api.runpod.ai/v2/your-pod-id/runsync
RUNPOD_ENDPOINT_URL=https://api.runpod.ai/v2/your-pod-id/runsync
RUNPOD_API_KEY=rpa_xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# URL publique du service en production
APP_URL="http://localhost:3000"

